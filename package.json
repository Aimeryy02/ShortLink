    "express-rate-limit": "^7.5.0",
    "geoip-lite": "^1.2.2",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
