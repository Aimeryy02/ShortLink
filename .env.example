# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/shortlink

# Security
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# URL Settings
SHORT_CODE_LENGTH=6
MAX_URL_LENGTH=2048

# Google Safe Browsing (optional)
GOOGLE_API_KEY=

# QR Code
QR_DEFAULT_SIZE=400
