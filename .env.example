# ============================================
# ShortLink - Environment Configuration
# ============================================

# SERVER
PORT=3000
NODE_ENV=development
# Prod: NODE_ENV=production

# DATABASE
MONGO_URI=mongodb://localhost:27017/shortlink
# Prod: MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/shortlink

# FRONTEND (CORS)
CLIENT_URL=http://localhost:5173
# Prod: CLIENT_URL=https://shortlink.vercel.app

# API BASE URL (for link generation)
BASE_URL=http://localhost:3000
# Prod: BASE_URL=https://shortlink-api.render.com

# SECURITY
BCRYPT_ROUNDS=10

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes = 900000 ms
RATE_LIMIT_MAX_REQUESTS=100
# Requests allowed per window per IP

# SHORT CODE GENERATION
SHORT_CODE_LENGTH=6
# Length of randomly generated short codes

# QR CODE
QR_DEFAULT_SIZE=400
# Default size in pixels (allowed: 200, 400, 600)

# LOGGING
LOG_LEVEL=info
# Values: trace, debug, info, warn, error, fatal

# Optional: Analytics/Monitoring
# SENTRY_DSN=
# DATADOG_API_KEY=

